#============================================================
# EditorConfig is awesome: https://EditorConfig.org
#============================================================

# Root configuration
root = true

# ============================================================
# Global settings (all files)
# ============================================================
[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 100

# ============================================================
# JSON files
# ============================================================
[*.json]
indent_size = 2

# ============================================================
# YAML files
# ============================================================
[*.yml]
indent_style = space
indent_size = 2

# ============================================================
# Ignore build output
# ============================================================
[dist/**]
indent_style = unset